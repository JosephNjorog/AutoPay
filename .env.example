# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tuma:password@localhost:5432/tuma_db
DATABASE_SSL=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Operations API (protects /api/ops/* recovery endpoints) ──────────────────
OPERATIONS_API_TOKEN=change_me_operations_token_min_32_chars

# ── Worker / Scanner Health ──────────────────────────────────────────────────
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_HEARTBEAT_STALE_SECONDS=120
SCANNER_HEARTBEAT_STALE_SECONDS=900
# One-shot Render cron monitor request timeout
HEARTBEAT_MONITOR_TIMEOUT_MS=30000

# ── Wallet Derivation (keep this secret — all user wallets derive from it) ────
WALLET_DERIVE_SECRET=change_me_wallet_secret_min_64_chars

# ── Avalanche ─────────────────────────────────────────────────────────────────
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43114
AVALANCHE_FUJI_CHAIN_ID=43113
RELAYER_PRIVATE_KEY=0x_your_relayer_eoa_private_key
# Separate signer key for authorising escrow claims (never rotate after launch)
SIGNER_PRIVATE_KEY=0x_your_signer_eoa_private_key
SIGNER_ADDRESS=0x_your_signer_eoa_address

# Smart contract addresses (set after deploy)
AUTOPAYKE_REGISTRY_ADDRESS=0x
AUTOPAYKE_FACTORY_ADDRESS=0x
AUTOPAYKE_ESCROW_ADDRESS=0x
AUTOPAYKE_PAYMASTER_ADDRESS=0x

# Chain-event reconciliation scanner (runs in escrow.worker / worker:all)
CHAIN_EVENT_SCAN_LOOKBACK_BLOCKS=100000
CHAIN_EVENT_SCAN_BATCH_BLOCKS=2000
CHAIN_EVENT_SCAN_CONFIRMATIONS=2

# Token addresses — optional, code already defaults correctly per network
# (mainnet Circle USDC/Tether USDT, or Circle's Fuji USDC faucet contract on
# testnet). Only set these to override.
USDC_ADDRESS=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E
USDT_ADDRESS=0x9702230A8Ea53601f5cD2dc00fDBc13d4dF4A8c7

# ── Resend (OTP email — primary delivery channel) ─────────────────────────────
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL="Autopayke <noreply@autopayke.com>"

# ── Twilio (OTP SMS fallback — used only if no email is on file) ──────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1your_twilio_number

# ── Africa's Talking (WhatsApp claim-link notifications) ──────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
AT_WHATSAPP_SENDER=your_whatsapp_sender_id
AT_WHATSAPP_OTP_TEMPLATE=tuma_otp

# ── FX Rates ──────────────────────────────────────────────────────────────────
OPEN_EXCHANGE_RATES_APP_ID=your_openexchangerates_app_id
FX_SPREAD=0.023

# ── M-Pesa (Daraja) ───────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_safaricom_consumer_key
MPESA_CONSUMER_SECRET=your_safaricom_consumer_secret
MPESA_SHORTCODE=your_paybill_or_till_number
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_B2C_INITIATOR=your_initiator_name
MPESA_B2C_CREDENTIAL=your_security_credential
MPESA_ENV=sandbox

# ── M-Pesa Merchant Pay (Daraja B2B — Till/PayBill) — sandbox only ────────────
# A separate Daraja sandbox app from the B2C credentials above.
MPESA_B2B_CONSUMER_KEY=your_daraja_b2b_sandbox_consumer_key
MPESA_B2B_CONSUMER_SECRET=your_daraja_b2b_sandbox_consumer_secret
MPESA_B2B_SECURITY_CREDENTIAL=your_daraja_b2b_sandbox_security_credential
MPESA_B2B_INITIATOR=testapi
MPESA_B2B_SHORTCODE=600000
# Merchant Pay defaults OFF everywhere unless this is explicitly "true" (see
# routes/pay.ts) — leave unset in production until Daraja go-live is ready.
# The on-chain leg is separately hard-pinned to Fuji testnet regardless
# (see services/avalanche-pay.ts), so this flag is defense-in-depth, not the
# only safeguard.
PAY_FEATURE_ENABLED=false

# ── MTN MoMo ──────────────────────────────────────────────────────────────────
MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MOMO_API_USER=your_mtn_api_user_uuid
MOMO_API_KEY=your_mtn_api_key
MOMO_ENV=sandbox
MOMO_CALLBACK_URL=https://api.tuma.app/webhooks/momo

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ── Minisend (contributor withdraw off-ramp: KE/NG/GH/UG) ─────────────────────
MINISEND_API_KEY=ms_live_your_minisend_key
MINISEND_WEBHOOK_SECRET=your_minisend_webhook_secret
MINISEND_BASE_URL=https://merchant.minisend.xyz

# ── Wave ──────────────────────────────────────────────────────────────────────
WAVE_API_KEY=your_wave_api_key
WAVE_BUSINESS_ID=your_wave_business_id

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
